- 总字数：${bookInfo.totalWords}

# 章节列表
${bookInfo.chapters.map(ch => `${ch.number}. ${ch.title} (${ch.wordCount}字)`).join('\n')}

# 前10章完整内容
${sampleChapters.map(ch => `
