#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

// 读取配置文件
let config = {};
const configPath = path.join(__dirname, 'config.json');
if (fs.existsSync(configPath)) {
  try {
    config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
  } catch (e) {
    console.error('⚠️  Failed to parse config.json');
  }
}

const AIService = require('./lib/ai-service');
const JsonExtractor = require('./lib/json-extractor');
const ProgressTracker = require('./lib/progress-tracker');
const { ErrorHandler } = require('./lib/error-handler');
const EnhancedPrompts = require('./lib/enhanced-prompts');
const CompactPrompts = require('./lib/compact-prompts');
const UltraCompactPrompts = require('./lib/ultra-compact-prompts');
const TwoStepPrompts = require('./lib/two-step-prompts');
const DataAdapter = require('./lib/data-adapter');

// 解析命令行参数
const args = process.argv.slice(2);
const command = args[0];
const bookFile = args[1];

if (!command || !bookFile) {
  console.log('Usage: ./book-parser analyze <book.txt> [options]');
  console.log('');
  console.log('Options:');
  console.log('  --output <dir>         输出目录 (默认: ./output)');
  console.log('  --chapters <n>         解析章节数量 (默认: 全部)');
  console.log('  --auto                 开启全自动 AI 营销分析 (DNA -> 画像 -> 卖点 -> 创意)');
  console.log('  --two-step             两步提取（先梗概后分析，覆盖全部章节）🔥推荐');
  console.log('  --compact              精简模式（前3章，减少token）');
  console.log('  --ultra-compact        超精简模式（前3章，最小输出，避免100秒超时）⚡');
  console.log('  --api-key <key>        AI API Key (也可通过环境变量 API_KEY 设置)');
  console.log('  --api-provider <p>     AI 提供商: gemini|claude (默认: gemini)');
  console.log('');
  console.log('Examples:');
  console.log('  ./book-parser analyze book.txt --auto --two-step      # 推荐：全章节分析');
  console.log('  ./book-parser analyze book.txt --auto --ultra-compact # 快速：前3章');
  process.exit(1);
}

// 解析可选参数
let outputDir = './output';
let maxChapters = null;
let autoAnalyze = false;
let compactMode = false;
let ultraCompactMode = false;
let twoStepMode = false;
let apiKey = (process.env.API_KEY || process.env.GEMINI_API_KEY || process.env.CLAUDE_API_KEY || config.apiKey);
let apiProvider = config.provider || 'gemini';

for (let i = 2; i < args.length; i++) {
  if (args[i] === '--output' && args[i + 1]) {
    outputDir = args[i + 1];
    i++;
  } else if (args[i] === '--chapters' && args[i + 1]) {
    maxChapters = parseInt(args[i + 1]);
    i++;
  } else if (args[i] === '--auto') {
    autoAnalyze = true;
  } else if (args[i] === '--two-step') {
    twoStepMode = true;
    ultraCompactMode = false;
    compactMode = false;
  } else if (args[i] === '--ultra-compact') {
    ultraCompactMode = true;
    compactMode = false;
    twoStepMode = false;
  } else if (args[i] === '--compact') {
    compactMode = true;
    twoStepMode = false;
  } else if (args[i] === '--api-key' && args[i + 1]) {
    apiKey = args[i + 1];
    i++;
  } else if (args[i] === '--api-provider' && args[i + 1]) {
    apiProvider = args[i + 1];
    i++;
  }
}

// 读取书籍文件
if (!fs.existsSync(bookFile)) {
  console.error(`Error: File not found: ${bookFile}`);
  process.exit(1);
}

const bookContent = fs.readFileSync(bookFile, 'utf-8');

// 解析章节
function parseChapters(content) {
  const chapters = [];
  const chapterRegex = /(?:【\s*第\s*\d+\s*章\s*】|第\s*[一二三四五六七八九十百千\d]+\s*章|Chapter\s*\d+)\s*(.+?)(?=\n|$)/gi;
  
  let match;
  const positions = [];
  while ((match = chapterRegex.exec(content)) !== null) {
    positions.push({ index: match.index, title: match[0], name: match[1] });
  }
  
  for (let i = 0; i < positions.length; i++) {
    const start = positions[i].index;
    const end = i < positions.length - 1 ? positions[i + 1].index : content.length;
    const chapterContent = content.substring(start, end).trim();
    chapters.push({
      number: i + 1,
      title: positions[i].title,
      name: positions[i].name,
      content: chapterContent,
      wordCount: chapterContent.length
    });
    if (maxChapters && chapters.length >= maxChapters) break;
  }
  return chapters;
}

console.log('📚 Step 1/6: 解析章节文本...');
const chapters = parseChapters(bookContent);
console.log(`✅ 找到 ${chapters.length} 个章节`);

if (!fs.existsSync(outputDir)) fs.mkdirSync(outputDir, { recursive: true });
const chaptersDir = path.join(outputDir, 'chapters');
if (!fs.existsSync(chaptersDir)) fs.mkdirSync(chaptersDir, { recursive: true });

chapters.forEach((chapter, index) => {
  const chapterFile = path.join(chaptersDir, `chapter-${String(index + 1).padStart(3, '0')}.json`);
  fs.writeFileSync(chapterFile, JSON.stringify(chapter, null, 2));
});
console.log(`✅ 章节已保存到: ${chaptersDir}`);

const analysisPrompt = generateAnalysisPrompt(chapters);
const promptFile = path.join(outputDir, 'analysis-prompt.txt');
fs.writeFileSync(promptFile, analysisPrompt);
console.log(`✅ 分析提示词已生成: ${promptFile}`);

if (autoAnalyze) {
  if (apiKey) {
    runFullAutomation();
  } else {
    console.log('\n🤖 Step 2/6: AI 分析准备就绪 (等待提供 API Key)...');
    const taskFile = path.join(outputDir, '.task.json');
    ErrorHandler.writeJsonFile(taskFile, {
      step: 'analyze',
      outputDir: outputDir,
      timestamp: Date.now()
    });
    console.log('📝 任务已创建。请提供 API Key 以继续。');
  }
} else {
  console.log('\n📝 下一步：使用 --auto 参数运行全自动分析。');
}

/**
 * 运行全自动工作流
 */
async function runFullAutomation() {
  console.log('\n🚀 启动全自动分析流程...');
  
  // 初始化进度追踪器
  const tracker = new ProgressTracker(outputDir);
  
  try {
    const aiService = new AIService({
      apiKey: apiKey,
      provider: apiProvider,
      model: config.model,
      baseUrl: config.baseUrl
    });

    let parsed;

    if (twoStepMode) {
      // 两步提取模式
      console.log('🔄 使用两步提取模式（全章节覆盖）');
      console.log('🤖 Step 2a/6: 正在提取章节梗概...');
      console.log('⏳ 请稍候 (预计 30-60 秒)...');

      tracker.startStep('chapter-summary');
      
      // Step 2a: 提取章节梗概
      const summaryPrompt = TwoStepPrompts.chapterSummaryExtraction(chapters);
      const summaryResult = await ErrorHandler.retry(
        () => aiService.chat(summaryPrompt),
        {
          maxRetries: 3,
          delayMs: 3000,
          backoff: true,
          stepName: 'chapter-summary',
          onRetry: (msg) => tracker.log('warn', msg)
        }
      );
      
      const summaryJson = JsonExtractor.extract(summaryResult);
      const chapterSummaries = JSON.parse(summaryJson);
      
      tracker.log('info', `章节梗概提取成功，覆盖 ${chapterSummaries.chapters?.length || 0} 章`);
      tracker.completeStep('chapter-summary', {
        chapters: chapterSummaries.chapters?.length
      });

      // 保存梗概
      const summaryFile = path.join(outputDir, 'chapter-summaries.json');
      ErrorHandler.writeJsonFile(summaryFile, chapterSummaries);
      console.log(`✅ 章节梗概已保存: ${summaryFile}`);

      // Step 2b: 基于梗概做 DNA 分析
      console.log('🤖 Step 2b/6: 正在提取书籍核心基因 (DNA)...');
      console.log('⏳ 请稍候 (预计 20-40 秒)...');

      tracker.startStep('dna-extraction');
      
      const bookInfo = {
        totalChapters: chapters.length,
        totalWords: chapters.reduce((sum, ch) => sum + ch.wordCount, 0)
      };
      
      const dnaPrompt = TwoStepPrompts.dnaFromSummaries(bookInfo, chapterSummaries);
      const analysisResult = await ErrorHandler.retry(
        () => aiService.chat(dnaPrompt),
        {
          maxRetries: 3,
          delayMs: 3000,
          backoff: true,
          stepName: 'dna-extraction',
          onRetry: (msg) => tracker.log('warn', msg)
        }
      );
      
      const jsonContent = JsonExtractor.extract(analysisResult);
      parsed = JSON.parse(jsonContent);
      
      // 转换为标准格式
      tracker.log('info', '检测到精简格式，正在转换为标准格式...');
      parsed = DataAdapter.adaptUltraCompactToStandard(parsed);
      
    } else {
      // 原有的单步提取模式
      console.log('🤖 Step 2/6: 正在提取书籍核心基因 (DNA)...');
      console.log('⏳ 请稍候 (预计 30-90 秒)...');

      tracker.startStep('dna-extraction');
      
      const analysisResult = await ErrorHandler.retry(
        () => aiService.chat(analysisPrompt),
        {
          maxRetries: 3,
          delayMs: 3000,
          backoff: true,
          stepName: 'dna-extraction',
          onRetry: (msg) => tracker.log('warn', msg)
        }
      );
      
      const jsonContent = JsonExtractor.extract(analysisResult);
      parsed = JSON.parse(jsonContent);
      
      // 如果是超精简模式，转换为标准格式
      if (ultraCompactMode && !parsed.bookAnalysis) {
        tracker.log('info', '检测到超精简格式，正在转换为标准格式...');
        parsed = DataAdapter.adaptUltraCompactToStandard(parsed);
      }
    }
    
    tracker.log('info', `DNA 提取成功，包含 ${Object.keys(parsed.bookAnalysis || {}).length} 个分析维度`);

    const analysisFile = path.join(outputDir, 'book-analysis.json');
    ErrorHandler.writeJsonFile(analysisFile, parsed);
    console.log(`✅ DNA 提取完成: ${analysisFile}`);
    
    tracker.completeStep('dna-extraction', {
      outputFile: analysisFile,
      dimensions: Object.keys(parsed.bookAnalysis || {}).length
    });

    const taskFile = path.join(outputDir, '.task.json');
    ErrorHandler.writeJsonFile(taskFile, {
      outputDir: outputDir,
      apiKey: apiKey,
      apiProvider: apiProvider,
      model: config.model,
      baseUrl: config.baseUrl,
      timestamp: Date.now()
    });

    console.log('\n🔗 正在触发后续自动化工作流 (画像、卖点、创意)...');
    const scriptDir = path.dirname(path.resolve(process.argv[1]));
    const autoWorkflowScript = path.join(scriptDir, 'auto-workflow');

    execSync(`${autoWorkflowScript} "${taskFile}"`, { stdio: 'inherit' });
    console.log('\n🏆 全链路分析流程顺利完成！');
    
    tracker.printSummary();
  } catch (error) {
    tracker.log('error', `全自动流程执行失败: ${error.message}`);
    ErrorHandler.saveError(error, outputDir, 'book-parser');
    tracker.printSummary();
    console.error('\n❌ 全自动流程执行失败:', error.message);
    process.exit(1);
  }
}

function generateAnalysisPrompt(chapters) {
  const bookInfo = {
    totalChapters: chapters.length,
    totalWords: chapters.reduce((sum, ch) => sum + ch.wordCount, 0),
    chapters: chapters.map(ch => ({
      number: ch.number,
      title: ch.title,
      name: ch.name,
      wordCount: ch.wordCount
    }))
  };
  
  const sampleChapters = chapters.slice(0, Math.min(10, chapters.length));
  
  // 根据模式选择 prompt
  if (ultraCompactMode) {
    console.log('⚡ 使用超精简模式（前3章，最小输出，<100秒）');
    return UltraCompactPrompts.dnaExtractionUltraCompact(bookInfo, sampleChapters);
  } else if (compactMode) {
    console.log('📦 使用精简模式（前3章，减少token消耗）');
    return CompactPrompts.dnaExtractionCompact(bookInfo, sampleChapters);
  } else {
    return EnhancedPrompts.dnaExtraction(bookInfo, sampleChapters);
  }
}
