#!/usr/bin/env node

/**
 * Report Generator
 * 将所有分析生成的 JSON 数据整合为一份美观的 Markdown 营销报告
 */

const fs = require('fs');
const path = require('path');

const outputDir = process.argv[2] || './output';

if (!fs.existsSync(outputDir)) {
  console.error(`❌ 错误: 目录 ${outputDir} 不存在`);
  process.exit(1);
}

const reportFile = path.join(outputDir, 'MARKETING-REPORT.md');

// 读取各个数据文件
const readJson = (file) => {
  const filePath = path.join(outputDir, file);
  if (fs.existsSync(filePath)) {
    return JSON.parse(fs.readFileSync(filePath, 'utf-8'));
  }
  return null;
};

const analysis = readJson('book-analysis.json');
const sellingPoints = readJson('selling-points-compare.json');
const creativeDirections = readJson('ad-creative-directions.json');
const audienceProfile = readJson('audience-profile-reverse-engineered.json');

if (!analysis) {
  console.error('❌ 错误: 未找到 book-analysis.json，无法生成报告');
  process.exit(1);
}

let md = `# 📖 丛书营销全案分析报告\n\n`;
md += `> 生成时间: ${new Date().toLocaleString()}\n\n`;

// 安全访问辅助函数
const safe = (obj, path, defaultValue = 'N/A') => {
  try {
    return path.split('.').reduce((o, p) => o?.[p], obj) ?? defaultValue;
  } catch {
    return defaultValue;
  }
};

// 1. 书籍概览
md += `## 1. 书籍 DNA 与核心定位\n\n`;
const info = analysis.bookAnalysis.basicInfo;
md += `### 🎯 核心挂钩 (Core Hook)\n**${info.coreHook}**\n\n`;
md += `- **类型**: ${info.genre}\n`;
md += `- **子类型**: ${(info.subGenres || []).join(', ')}\n`;
md += `- **关键词**: ${(info.keywords || []).join(', ')}\n\n`;

md += `### 🧬 书籍基因 (Book DNA)\n`;
md += `- **上瘾指数**: ${analysis.bookAnalysis.addictionIndex.score}/10 (${analysis.bookAnalysis.addictionIndex.level})\n`;
const paceReason = safe(analysis, 'bookAnalysis.addictionIndex.factors.paceControl.reason', '节奏控制良好');
md += `- **节奏控制**: ${paceReason}\n`;
const emotions = (analysis.bookAnalysis.bookDNA?.emotionWave || []).map(e => e.emotion).join(' → ');
md += `- **情感波动**: ${emotions || '情感起伏丰富'}。\n\n`;

// 2. 角色与冲突
md += `## 2. 角色图谱与冲突焦点\n\n`;
md += `### 👤 核心角色\n`;
const allChars = (analysis.bookAnalysis.characters.supporting || []).concat(analysis.bookAnalysis.characters.protagonist ? [analysis.bookAnalysis.characters.protagonist] : []);
allChars.forEach(char => {
  if (char && char.name) {
    md += `- **${char.name}**: ${char.role || '主角'} (${char.relationship || '核心情境'})\n`;
  }
});
md += `\n### ⚔️ 主要冲突\n`;
analysis.bookAnalysis.plot.mainConflicts.forEach(conflict => {
  md += `- ${conflict}\n`;
});
md += `\n`;

// 情节划分与曲线
if (analysis.bookAnalysis.plot.chapterBreakdown) {
  md += `### 📈 情节划分与节奏曲线\n\n`;
  md += `| 章节 | 阶段 | 剧情焦点 | 张力指数 | 钩子类型 |\n`;
  md += `| :--- | :--- | :--- | :--- | :--- |\n`;
  analysis.bookAnalysis.plot.chapterBreakdown.forEach(item => {
    const bars = '🔥'.repeat(Math.round(item.intensity * 5));
    md += `| ${item.chapter} | ${item.phase} | ${item.summary} | ${bars} (${item.intensity}) | ${item.hookType} |\n`;
  });
  md += `\n> **情节曲线综述**: ${analysis.bookAnalysis.plot.plotCurve}\n\n`;
}

// 3. 受众画像
if (audienceProfile || analysis.audienceProfile) {
  const profile = audienceProfile || analysis.audienceProfile;
  md += `## 3. 👥 目标受众画像 (Enriched Persona)\n\n`;
  md += `### 核心受众特征\n`;
  md += `- **年龄段**: ${profile.primary.age}\n`;
  md += `- **性别**: ${profile.primary.gender}\n`;
  md += `- **核心痛点**: ${Array.isArray(profile.primary.painPoints) ? profile.primary.painPoints.join(', ') : profile.primary.painPoints}\n`;
  md += `- **情感诉求**: ${Array.isArray(profile.primary.desires) ? profile.primary.desires.join(', ') : profile.primary.desires}\n`;
  md += `- **重点出海地区**: ${Array.isArray(profile.primary.location) ? profile.primary.location.join(', ') : profile.primary.location}\n\n`;
  
  if (profile.psychographics) {
    md += `### 🧠 心理与审美分析\n`;
    md += `- **心理驱动力**: ${profile.psychographics.psychologicalDrivers || 'N/A'}\n`;
    md += `- **审美偏好**: ${profile.psychographics.aesthetic || 'N/A'}\n\n`;
  }
  
  if (profile.behavioral) {
    md += `### 📱 阅读习惯\n`;
    md += `- **阅读行为**: ${profile.behavioral.readingHabits || 'N/A'}\n\n`;
  }
}

// 4. 核心适配卖点 (DNA + 人群)
if (sellingPoints) {
  md += `## 4. 💰 核心适配卖点提炼\n\n`;
  sellingPoints.finalSellingPoints.forEach((sp, index) => {
    md += `### 卖点 ${index + 1}: ${sp.title}\n`;
    md += `> **一句话 Hook**: ${sp.oneLinePitch}\n\n`;
    md += `- **心理触发**: ${sp.psychologicalTriggers}\n`;
    
    if (sp.scoring) {
      const getStars = (score) => '⭐'.repeat(Math.round(score / 2 || 0)) + '🌑'.repeat(5 - Math.round(score / 2 || 0));
      md += `\n#### 📊 潜力评估\n`;
      md += `- **市场吸引力**: ${getStars(sp.scoring.marketAppeal)} (${sp.scoring.marketAppeal}/10)\n`;
      md += `- **独特度**: ${getStars(sp.scoring.uniqueness)} (${sp.scoring.uniqueness}/10)\n`;
      md += `- **情感冲击力**: ${getStars(sp.scoring.emotionalImpact)} (${sp.scoring.emotionalImpact}/10)\n`;
      md += `- **综合推荐指数**: **${sp.scoring.overallScore}/10**\n`;
    }
    md += `\n---\n\n`;
  });
}

// 5. 创意方向 (DNA + 人群 + 卖点)
if (creativeDirections) {
  md += `## 5. 🎬 核心创意方向与脚本\n\n`;
  creativeDirections.creativeDirections.forEach((cd, index) => {
    md += `### 创意方案 ${index + 1}: ${cd.emotionalAngle || '爆款逻辑'}\n`;
    md += `> **视频视觉钩子**: ${cd.creativeHook}\n\n`;
    
    md += `#### 📺 制作 Brief\n`;
    md += `- **画面细节**: ${cd.visualBrief}\n`;
    
    // Check for scripts block or direct tiktok/facebook properties
    if (cd.scripts || cd.tiktok || cd.facebook) {
      md += `\n#### ✍️ 投放文案\n`;
      if (cd.scripts && cd.scripts.facebook) {
        md += `- **Facebook/Meta**: \n  - *Headline*: ${cd.scripts.facebook.headline}\n  - *Primary Text*: ${cd.scripts.facebook.primaryText.replace(/\n/g, '\n    ')}\n`;
      } else if (cd.facebook) { // Handle direct facebook property if it exists
        md += `- **Facebook/Meta**: \n  - *Headline*: ${cd.facebook.headline}\n  - *Primary Text*: ${cd.facebook.primaryText.replace(/\n/g, '\n    ')}\n`;
      }
      if (cd.tiktok) {
        md += `- **TikTok**: \n  - *Video Script*: ${cd.tiktok.videoScript}\n  - *Caption*: ${cd.tiktok.caption}\n`;
      } else if (cd.scripts && cd.scripts.tiktok) { // Fallback to old structure if new one not present
        md += `- **TikTok**: \n  - *Video Script*: ${cd.scripts.tiktok.videoScript}\n  - *Caption*: ${cd.scripts.tiktok.caption}\n`;
      }
    }
    md += `\n---\n\n`;
  });
}

md += `\n> Generated by Book Parser Logic Engine (Autonomous Workflow).\n`;

fs.writeFileSync(reportFile, md);
console.log(`✅ 完整营销报告已生成: ${reportFile}`);
