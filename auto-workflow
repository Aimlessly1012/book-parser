#!/usr/bin/env node

/**
 * Book Parser Auto Workflow
 * 自动化完成书籍分析的完整流程
 */

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');
const AIService = require('./lib/ai-service');

// 读取任务文件
const taskFile = process.argv[2];

if (!taskFile || !fs.existsSync(taskFile)) {
  console.error('Usage: ./auto-workflow <task-file.json>');
  console.error('');
  console.error('This script is called by OpenClaw AI to complete the analysis workflow.');
  process.exit(1);
}

const task = JSON.parse(fs.readFileSync(taskFile, 'utf-8'));
const { outputDir, apiKey, apiProvider, model, baseUrl } = task;

console.log('🤖 开始全自动分析工作流...\n');

// 检查 book-analysis.json 是否存在 (由 Step 2 完成)
const analysisFile = path.join(outputDir, 'book-analysis.json');
if (!fs.existsSync(analysisFile)) {
  console.error('❌ 错误: book-analysis.json 不存在');
  console.error('   请确保 Step 2 (核心 DNA 提取) 已完成');
  process.exit(1);
}

const analysis = JSON.parse(fs.readFileSync(analysisFile, 'utf-8'));
console.log('✅ Step 2/6: 书籍核心基因 (DNA) 已就绪');
console.log(`   类型: ${analysis.bookAnalysis.basicInfo.genre}`);
console.log(`   关键词: ${analysis.bookAnalysis.basicInfo.searchKeywords.join(', ')}\n`);

async function runWorkflow() {
  if (!apiKey) {
    console.error('❌ 错误: 未提供 API Key，无法执行自主 AI 流程');
    process.exit(1);
  }

  try {
    // Step 3: 生成精确人群画像 (DNA -> Profile)
    console.log('👥 Step 3/6: 正在自主生成目标受众画像...');
    await retry(() => runAutonomousProfileGeneration());

    // Step 4: 基于画像提炼核心卖点并打分 (DNA + Profile -> Selling Points)
    console.log('📊 Step 4/6: 正在提炼适配卖点并进行多维度打分...');
    await retry(() => runAutonomousSellingPointGeneration());

    // Step 5: 基于卖点产出创意方向 (DNA + Profile + Selling Points -> Creative)
    console.log('🎬 Step 5/6: 正在产出高转化广告创意方向...');
    await retry(() => runAutonomousCreativeGeneration());

    // Step 6: 生成综合营销报告
    console.log('📝 Step 6/6: 正在聚合数据并生成最终营销报告...');
    const scriptDir = path.dirname(process.argv[1]);
    const reportGeneratorScript = path.join(scriptDir, 'report-generator');
    execSync(`${reportGeneratorScript} "${outputDir}"`, { stdio: 'inherit' });

    console.log('\n✨ 全链路自动化工作流执行完毕！');
    console.log('📁 核心产出:');
    console.log(`   ${outputDir}/MARKETING-REPORT.md  <-- 最终全案\n`);
  } catch (error) {
    console.error(`\n❌ 工作流执行中断: ${error.message}`);
    process.exit(1);
  }
}

/**
 * 带有重试机制的函数执行器
 */
async function retry(fn, retries = 2) {
  for (let i = 0; i <= retries; i++) {
    try {
      return await fn();
    } catch (err) {
      if (i === retries) throw err;
      console.warn(`   ⚠️  执行失败，正在进行第 ${i + 1} 次重试... (${err.message})`);
      await new Promise(r => setTimeout(r, 2000));
    }
  }
}

/**
 * 运行自主画像生成 (DNA -> Profile)
 */
async function runAutonomousProfileGeneration() {
  const ourBook = JSON.parse(fs.readFileSync(analysisFile, 'utf-8'));
  const profilePrompt = `你是一位专业的人群画像分析师。请根据以下书籍分析结果，反推并生成一个极其详细的目标人群画像。不需要参考竞品，直接从本书的核心基因、情节走向和情感冲突中推断。

# 书籍深度分析 (DNA)
${JSON.stringify(ourBook, null, 2)}

# 任务目标
请输出 JSON 格式（只输出 JSON）：
{
  "primary": {
    "age": "年龄段",
    "gender": "性别倾向",
    "occupation": ["职场人", "学生"],
    "location": ["美国", "东南亚"],
    "painPoints": ["痛点1", "痛点2"],
    "desires": ["动机1", "动机2"]
  },
  "behavioral": {
    "readingHabits": "阅读场景描述",
    "genreFamiliarity": "熟悉程度",
    "platforms": ["TikTok", "WebNovel"]
  },
  "psychographics": {
    "psychologicalDrivers": "深层心理驱动力",
    "aesthetic": "审美偏好（视频画面风格）",
    "readingTriggers": "触发阅读、点击的核心点"
  },
  "keyInsights": ["洞察1", "洞察2"]
}`;

  const aiService = new AIService({ apiKey, provider: apiProvider, model, baseUrl });
  const result = await aiService.chat(profilePrompt);
  const jsonContent = extractJson(result);
  
  // 验证 JSON
  JSON.parse(jsonContent); 
  
  const targetFile = path.join(outputDir, 'audience-profile-reverse-engineered.json');
  fs.writeFileSync(targetFile, jsonContent);
  console.log('   ✅ 受众画像已生成\n');
}

/**
 * 运行核心卖点提炼与评分 (DNA + Profile -> Selling Points)
 */
async function runAutonomousSellingPointGeneration() {
  const ourBook = JSON.parse(fs.readFileSync(analysisFile, 'utf-8'));
  const profileFile = path.join(outputDir, 'audience-profile-reverse-engineered.json');
  if (!fs.existsSync(profileFile)) throw new Error('受众画像文件丢失');
  
  const profile = JSON.parse(fs.readFileSync(profileFile, 'utf-8'));

  const generationPrompt = `你是一位顶尖的网文出海营销专家。请根据书籍分析结果和目标受众画像，提炼出最能打动该人群的**适配卖点**，并进行 1-10 分深度评分。

# 书籍 DNA
${JSON.stringify(ourBook, null, 2)}

# 目标受众画像
${JSON.stringify(profile, null, 2)}

# 任务要求
请输出 JSON 格式（只输出 JSON）：
{
  "finalSellingPoints": [
    {
      "pointId": "SP001",
      "title": "卖点标题",
      "oneLinePitch": "一句话核心文案",
      "priority": "极高/中/低",
      "psychologicalTriggers": "背后的心理动机",
      "scoring": {
        "marketAppeal": 9,
        "uniqueness": 8,
        "emotionalImpact": 10,
        "overallScore": 9
      }
    }
  ],
  "competitiveAdvantage": { "summary": "核心竞争力评价" }
}`;

  const aiService = new AIService({ apiKey, provider: apiProvider, model, baseUrl });
  const result = await aiService.chat(generationPrompt);
  const jsonContent = extractJson(result);
  
  // 验证 JSON
  JSON.parse(jsonContent);

  const outputFile = path.join(outputDir, 'selling-points-compare.json');
  fs.writeFileSync(outputFile, jsonContent);
  console.log('   ✅ 适配卖点已生成\n');
}

/**
 * 运行创意方向产出 (DNA + Profile + Selling Points -> Creative)
 */
async function runAutonomousCreativeGeneration() {
  const ourBook = JSON.parse(fs.readFileSync(analysisFile, 'utf-8'));
  const profile = JSON.parse(fs.readFileSync(path.join(outputDir, 'audience-profile-reverse-engineered.json'), 'utf-8'));
  const sellingPointsFile = path.join(outputDir, 'selling-points-compare.json');
  if (!fs.existsSync(sellingPointsFile)) throw new Error('卖点分析文件丢失');
  
  const sellingPoints = JSON.parse(fs.readFileSync(sellingPointsFile, 'utf-8'));

  const creativePrompt = `你是一位顶级效果广告创意总监。请结合书籍基因、受众画像和核心卖点，产出高转化的广告创意方向（Facebook/TikTok）。

# 输入数据
- 核心信息: ${JSON.stringify(ourBook.bookAnalysis.basicInfo, null, 2)}
- 角色背景: ${JSON.stringify(ourBook.bookAnalysis.characters.protagonist, null, 2)}
- 受众画像: ${JSON.stringify(profile, null, 2)}
- 核心卖点: ${JSON.stringify(sellingPoints.finalSellingPoints, null, 2)}

# 产出目标
请输出 JSON 格式（只输出 JSON）：
{
  "creativeDirections": [
    {
      "pointId": "SP001",
      "creativeHook": "第一道视角视觉描述",
      "tiktok": { "videoScript": "视频前3秒、中间转折及结尾脚本", "caption": "配文" },
      "visualBrief": "视觉画面细节要求",
      "emotionalAngle": "挖掘的心理切入点"
    }
  ]
}
`;

  const aiService = new AIService({ apiKey, provider: apiProvider, model, baseUrl });
  const result = await aiService.chat(creativePrompt);
  const jsonContent = extractJson(result);
  
  // 验证 JSON
  JSON.parse(jsonContent);

  const outputFile = path.join(outputDir, 'ad-creative-directions.json');
  fs.writeFileSync(outputFile, jsonContent);
  console.log('   ✅ 创意方向已完成\n');
}

/**
 * 辅助函数：从 AI 回复中提取 JSON
 */
function extractJson(raw) {
  const start = raw.indexOf('{');
  const end = raw.lastIndexOf('}');
  if (start !== -1 && end !== -1 && end > start) {
    return raw.substring(start, end + 1);
  }
  return raw.trim();
}

// 启动工作流
runWorkflow();
