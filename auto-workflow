#!/usr/bin/env node

/**
 * Book Parser Auto Workflow (Enhanced)
 * 自动化完成书籍分析的完整流程
 * 
 * 优化点:
 * - 健壮的 JSON 提取
 * - 详细的错误处理和重试机制
 * - 进度追踪和断点恢复
 * - 完整的日志记录
 */

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');
const AIService = require('./lib/ai-service');
const JsonExtractor = require('./lib/json-extractor');
const ProgressTracker = require('./lib/progress-tracker');
const { ErrorHandler } = require('./lib/error-handler');
const EnhancedPrompts = require('./lib/enhanced-prompts');

// 读取任务文件
const taskFile = process.argv[2];

if (!taskFile || !fs.existsSync(taskFile)) {
  console.error('Usage: ./auto-workflow <task-file.json>');
  console.error('');
  console.error('This script is called by OpenClaw AI to complete the analysis workflow.');
  process.exit(1);
}

const task = ErrorHandler.readJsonFile(taskFile);
const { outputDir, apiKey, apiProvider, model, baseUrl } = task;

// 初始化进度追踪器
const tracker = new ProgressTracker(outputDir);

console.log('🤖 开始全自动分析工作流...\n');

// 检查 book-analysis.json 是否存在 (由 Step 2 完成)
const analysisFile = path.join(outputDir, 'book-analysis.json');
ErrorHandler.validateFiles(['book-analysis.json'], outputDir);

const analysis = ErrorHandler.readJsonFile(analysisFile);
console.log('✅ Step 2/6: 书籍核心基因 (DNA) 已就绪');
console.log(`   类型: ${analysis.bookAnalysis.basicInfo.genre}`);
console.log(`   关键词: ${analysis.bookAnalysis.basicInfo.searchKeywords.join(', ')}\n`);

async function runWorkflow() {
  if (!apiKey) {
    tracker.log('error', '未提供 API Key，无法执行自主 AI 流程');
    process.exit(1);
  }

  try {
    // Step 3: 生成精确人群画像 (DNA -> Profile)
    if (!tracker.isStepCompleted('profile-generation')) {
      console.log('👥 Step 3/6: 正在自主生成目标受众画像...');
      await ErrorHandler.wrap(
        () => ErrorHandler.retry(
          () => runAutonomousProfileGeneration(),
          {
            maxRetries: 3,
            delayMs: 2000,
            backoff: true,
            stepName: 'profile-generation',
            onRetry: (msg) => tracker.log('warn', msg)
          }
        ),
        'profile-generation',
        tracker
      );
    } else {
      console.log('⏭️  Step 3/6: 受众画像已存在，跳过');
    }

    // Step 4: 基于画像提炼核心卖点并打分 (DNA + Profile -> Selling Points)
    if (!tracker.isStepCompleted('selling-points-generation')) {
      console.log('📊 Step 4/6: 正在提炼适配卖点并进行多维度打分...');
      await ErrorHandler.wrap(
        () => ErrorHandler.retry(
          () => runAutonomousSellingPointGeneration(),
          {
            maxRetries: 3,
            delayMs: 2000,
            backoff: true,
            stepName: 'selling-points-generation',
            onRetry: (msg) => tracker.log('warn', msg)
          }
        ),
        'selling-points-generation',
        tracker
      );
    } else {
      console.log('⏭️  Step 4/6: 卖点分析已存在，跳过');
    }

    // Step 5: 基于卖点产出创意方向 (DNA + Profile + Selling Points -> Creative)
    if (!tracker.isStepCompleted('creative-generation')) {
      console.log('🎬 Step 5/6: 正在产出高转化广告创意方向...');
      await ErrorHandler.wrap(
        () => ErrorHandler.retry(
          () => runAutonomousCreativeGeneration(),
          {
            maxRetries: 3,
            delayMs: 2000,
            backoff: true,
            stepName: 'creative-generation',
            onRetry: (msg) => tracker.log('warn', msg)
          }
        ),
        'creative-generation',
        tracker
      );
    } else {
      console.log('⏭️  Step 5/6: 创意方向已存在，跳过');
    }

    // Step 6: 生成综合营销报告
    if (!tracker.isStepCompleted('report-generation')) {
      console.log('📝 Step 6/6: 正在聚合数据并生成最终营销报告...');
      await ErrorHandler.wrap(
        () => {
          const scriptDir = path.dirname(process.argv[1]);
          const reportGeneratorScript = path.join(scriptDir, 'report-generator');
          execSync(`${reportGeneratorScript} "${outputDir}"`, { stdio: 'inherit' });
          return Promise.resolve();
        },
        'report-generation',
        tracker
      );
    } else {
      console.log('⏭️  Step 6/6: 报告已存在，跳过');
    }

    console.log('\n✨ 全链路自动化工作流执行完毕！');
    console.log('📁 核心产出:');
    console.log(`   ${outputDir}/MARKETING-REPORT.md  <-- 最终全案\n`);
    
    tracker.printSummary();
  } catch (error) {
    tracker.log('error', `工作流执行中断: ${error.message}`);
    ErrorHandler.saveError(error, outputDir, 'workflow');
    tracker.printSummary();
    process.exit(1);
  }
}

/**
 * 运行自主画像生成 (DNA -> Profile)
 */
async function runAutonomousProfileGeneration() {
  const ourBook = ErrorHandler.readJsonFile(analysisFile);
  
  // 使用增强版 prompt
  const profilePrompt = EnhancedPrompts.audienceProfile(ourBook);

  const aiService = new AIService({ apiKey, provider: apiProvider, model, baseUrl });
  tracker.log('info', '正在调用 AI 生成受众画像...');
  
  const result = await aiService.chat(profilePrompt);
  const jsonContent = JsonExtractor.extract(result);
  
  // 验证 JSON 格式
  const parsed = JSON.parse(jsonContent);
  tracker.log('info', `受众画像生成成功，包含 ${Object.keys(parsed).length} 个维度`);
  
  const targetFile = path.join(outputDir, 'audience-profile-reverse-engineered.json');
  ErrorHandler.writeJsonFile(targetFile, parsed);
  console.log('   ✅ 受众画像已生成\n');
}

/**
 * 运行核心卖点提炼与评分 (DNA + Profile -> Selling Points)
 */
async function runAutonomousSellingPointGeneration() {
  const ourBook = ErrorHandler.readJsonFile(analysisFile);
  const profileFile = path.join(outputDir, 'audience-profile-reverse-engineered.json');
  ErrorHandler.validateFiles(['audience-profile-reverse-engineered.json'], outputDir);
  
  const profile = ErrorHandler.readJsonFile(profileFile);

  // 使用增强版 prompt
  const generationPrompt = EnhancedPrompts.sellingPoints(ourBook, profile);

  const aiService = new AIService({ apiKey, provider: apiProvider, model, baseUrl });
  tracker.log('info', '正在调用 AI 提炼适配卖点...');
  
  const result = await aiService.chat(generationPrompt);
  const jsonContent = JsonExtractor.extract(result);
  
  // 验证 JSON 格式
  const parsed = JSON.parse(jsonContent);
  tracker.log('info', `卖点提炼成功，共 ${parsed.finalSellingPoints?.length || 0} 个卖点`);

  const outputFile = path.join(outputDir, 'selling-points-compare.json');
  ErrorHandler.writeJsonFile(outputFile, parsed);
  console.log('   ✅ 适配卖点已生成\n');
}

/**
 * 运行创意方向产出 (DNA + Profile + Selling Points -> Creative)
 */
async function runAutonomousCreativeGeneration() {
  const ourBook = ErrorHandler.readJsonFile(analysisFile);
  const profile = ErrorHandler.readJsonFile(path.join(outputDir, 'audience-profile-reverse-engineered.json'));
  const sellingPointsFile = path.join(outputDir, 'selling-points-compare.json');
  ErrorHandler.validateFiles(['selling-points-compare.json'], outputDir);
  
  const sellingPoints = ErrorHandler.readJsonFile(sellingPointsFile);

  // 使用增强版 prompt
  const creativePrompt = EnhancedPrompts.creativeDirections(ourBook, profile, sellingPoints);

  const aiService = new AIService({ apiKey, provider: apiProvider, model, baseUrl });
  tracker.log('info', '正在调用 AI 产出创意方向...');
  
  const result = await aiService.chat(creativePrompt);
  const jsonContent = JsonExtractor.extract(result);
  
  // 验证 JSON 格式
  const parsed = JSON.parse(jsonContent);
  tracker.log('info', `创意方向生成成功，共 ${parsed.creativeDirections?.length || 0} 个方向`);

  const outputFile = path.join(outputDir, 'ad-creative-directions.json');
  ErrorHandler.writeJsonFile(outputFile, parsed);
  console.log('   ✅ 创意方向已完成\n');
}

// 启动工作流
runWorkflow();
