  const activeOnly = args.includes('--active-only');
  
  // 解析语言参数
  let bookLanguage = ['en'];
  const langIndex = args.indexOf('--language');
  if (langIndex !== -1 && args[langIndex + 1]) {
    bookLanguage = [args[langIndex + 1]];
  }
  
  // 解析时间范围
  let timeDimension = ['2025-10', '2025-11'];
  const timeIndex = args.indexOf('--time-range');
  if (timeIndex !== -1 && args[timeIndex + 1]) {
    timeDimension = args[timeIndex + 1].split(',');
  }
  
  try {
    // 查找相似书籍
    const similarBooks = await findSimilarBooks(keywords, {
      bookLanguage,
      timeDimension,
      activeOnly
    });
    
    // 生成报告
    const sorted = generateReport(keywords.join(', '), similarBooks);
    
    // 输出 JSON
    if (outputJSON || saveToFile) {
      const jsonData = generateJSON(keywords.join(', '), sorted);
      const jsonStr = JSON.stringify(jsonData, null, 2);
      
      if (saveToFile) {
        const filename = `book-ads-${Date.now()}.json`;
        fs.writeFileSync(filename, jsonStr);
        console.log(`\n✅ 已保存到: ${filename}`);
      }
      
      if (outputJSON) {
        console.log('\n' + '='.repeat(80));
        console.log('JSON 输出:');
        console.log('='.repeat(80));
        console.log(jsonStr);
      }
    }
    
  } catch (error) {
    console.error('❌ 错误:', error.message);
    process.exit(1);
  }
}

