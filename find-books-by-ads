/**
 * 生成 JSON 格式的相似书籍数据
 */
function generateJSON(targetBookName, books) {
  return {
    targetKeywords: targetBookName,
    totalFound: books.length,
    similarBooks: books.map(book => ({
      bookId: book.bookId,
      bookName: book.bookName,
      bookLanguage: book.bookLanguage,
      totalUniqueAds: book.totalUniqueAds,
      activeUniqueAds: book.activeUniqueAds,
      heatScore: book.heatScore,
      firstSeen: book.firstSeen,
      lastSeen: book.lastSeen,
      tags: book.tags || [],
      countries: book.countries || [],
      channels: book.channels || [],
      regions: book.allRegions || [],
      contentOrigin: book.contentOrigin,
      serializationStatus: book.serializationStatus,
      activityStatus: book.activityStatus,
      creativeTypes: book.creativeTypes || [],
      cover: book.cover
    })),
    generatedAt: new Date().toISOString()
  };
}

