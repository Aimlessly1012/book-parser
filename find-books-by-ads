/**
 * 查找相似书籍（基于关键词）
 */
async function findSimilarBooks(keywords, options = {}) {
  const {
    timeGranularity = 'month',
    timeDimension = ['2025-01', '2025-03'],  // 修改为更早的时间
    bookLanguage = ['en'],
    activeOnly = false,  // 改为 false，查询所有书籍
    pageSize = 20,
    sortBy = 'totalAds',
    sortDirection = 'desc'
  } = options;
  
  console.log(`\n📚 查找相似书籍: ${keywords.join(', ')}\n`);
  
  const allBooks = new Map();
  
  // 对每个关键词进行搜索
  for (const keyword of keywords) {
    try {
      const params = {
        timeGranularity,
        timeDimension,
        bookLanguage,
        activeOnly,
        pageSize,
        sortBy,
        sortDirection,
        bookName: keyword,
        pageIndex: 1
      };
      
      const result = await searchBooks(params);
      
      if (result.data && result.data.data) {
        result.data.data.forEach(book => {
          if (!allBooks.has(book.bookId)) {
            allBooks.set(book.bookId, book);
          }
        });
      }
      
      // 避免请求过快
      await new Promise(resolve => setTimeout(resolve, 500));
    } catch (error) {
      console.error(`❌ 搜索失败: ${keyword}`, error.message);
    }
  }
  
  return Array.from(allBooks.values());
}

/**
 * 分析书籍相似度
 */
function analyzeSimilarity(targetBook, compareBook) {
  let score = 0;
  let reasons = [];
  
  // 标签匹配（最重要）
  if (targetBook.tags && compareBook.tags) {
    const targetTags = new Set(targetBook.tags);
    const compareTags = new Set(compareBook.tags);
    const commonTags = [...targetTags].filter(tag => compareTags.has(tag));
    
    if (commonTags.length > 0) {
      score += 40;
      reasons.push(`共同标签: ${commonTags.join(', ')}`);
    }
  }
  
  // 语言匹配
  if (targetBook.bookLanguage === compareBook.bookLanguage) {
    score += 20;
    reasons.push('语言相同');
  }
  
  // 广告数量级相近
  const targetAds = targetBook.totalAds || 1;
  const compareAds = compareBook.totalAds || 1;
  const adsRatio = Math.max(targetAds, compareAds) / Math.min(targetAds, compareAds);
  
  if (adsRatio < 5) {
    score += 20;
    reasons.push('投放规模相近');
  }
  
  // 投放国家重叠
  if (targetBook.countries && compareBook.countries) {
    const targetCountries = new Set(targetBook.countries);
    const compareCountries = new Set(compareBook.countries);
    const commonCountries = [...targetCountries].filter(c => compareCountries.has(c));
    
    if (commonCountries.length > 0) {
      score += 10;
      reasons.push(`共同投放国家: ${commonCountries.length}个`);
    }
  }
  
  // 投放渠道重叠
  if (targetBook.channels && compareBook.channels) {
    const targetChannels = new Set(targetBook.channels);
    const compareChannels = new Set(compareBook.channels);
    const commonChannels = [...targetChannels].filter(c => compareChannels.has(c));
    
    if (commonChannels.length > 0) {
      score += 10;
      reasons.push(`共同投放渠道: ${commonChannels.length}个`);
    }
  }
  
  return { score, reasons };
}

